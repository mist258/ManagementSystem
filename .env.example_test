# for test docker database
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
DB_HOST=
DB_PORT=

# test db url
FASTAPI__DB_TEST__URL=postgresql+asyncpg://db_test_user:db_test_password@db_test_host:db_test_port/db_test_name

### NOTE
#In the URL, use the actual values instead of the variable names (like POSTGRES_DB);
#otherwise, the database won’t work.